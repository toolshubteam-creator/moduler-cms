@model IReadOnlyList<PostDto>
@{
    ViewData["Title"] = "Blog Posts";
}

<h1>Blog Posts</h1>

@if (TempData["SuccessMessage"] is string ok)
{
    <div role="alert" style="color:green;">@ok</div>
}
@if (TempData["ErrorMessage"] is string err)
{
    <div role="alert" style="color:red;">@err</div>
}

<p><a asp-action="Create">+ Yeni Post</a></p>

@if (Model.Count == 0)
{
    <p><em>Henuz post yok.</em></p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Id</th>
                <th>Title</th>
                <th>Slug</th>
                <th>Status</th>
                <th>PublishedAt</th>
                <th>Media</th>
                <th>Islemler</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Id</td>
                <td>@p.Title</td>
                <td><code>@p.Slug</code></td>
                <td>@p.Status</td>
                <td>@(p.PublishedAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                <td>@(p.FeaturedMediaId?.ToString() ?? "—")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@p.Id">Duzenle</a>
                    <span> | </span>
                    @if (p.Status == PostStatus.Draft)
                    {
                        <form asp-action="Publish" asp-route-id="@p.Id" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit">Yayinla</button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="Unpublish" asp-route-id="@p.Id" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit">Draft'a Al</button>
                        </form>
                    }
                    <span> | </span>
                    <form asp-action="Delete" asp-route-id="@p.Id" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" onclick="return confirm('Silinsin mi?');">Sil</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
