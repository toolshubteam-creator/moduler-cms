@model IReadOnlyList<CategoryTreeNodeDto>
@{
    ViewData["Title"] = "Blog Kategorileri";
}

<h1>Blog Kategorileri</h1>

@if (TempData["SuccessMessage"] is string ok)
{
    <div role="alert" style="color:green;">@ok</div>
}
@if (TempData["ErrorMessage"] is string err)
{
    <div role="alert" style="color:red;">@err</div>
}

<p><a asp-action="Create">+ Yeni Kategori</a></p>

@if (Model.Count == 0)
{
    <p><em>Henuz kategori yok.</em></p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Slug</th>
                <th>Parent</th>
                <th>Islemler</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var c in Model)
        {
            var indent = string.Concat(Enumerable.Repeat("— ", c.Depth));
            <tr>
                <td>@c.Id</td>
                <td>@indent@c.Name</td>
                <td><code>@c.Slug</code></td>
                <td>@(c.ParentCategoryId?.ToString() ?? "—")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@c.Id">Duzenle</a>
                    <span> | </span>
                    <form asp-action="Delete" asp-route-id="@c.Id" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" onclick="return confirm('Silinsin mi?');">Sil</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
