@model IReadOnlyList<TagDto>
@{
    ViewData["Title"] = "Blog Etiketleri";
}

<h1>Blog Etiketleri</h1>

@if (TempData["SuccessMessage"] is string ok)
{
    <div role="alert" style="color:green;">@ok</div>
}
@if (TempData["ErrorMessage"] is string err)
{
    <div role="alert" style="color:red;">@err</div>
}

<p><a asp-action="Create">+ Yeni Etiket</a></p>

@if (Model.Count == 0)
{
    <p><em>Henuz etiket yok.</em></p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Slug</th>
                <th>Islemler</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.Id</td>
                <td>@t.Name</td>
                <td><code>@t.Slug</code></td>
                <td>
                    <a asp-action="Edit" asp-route-id="@t.Id">Duzenle</a>
                    <span> | </span>
                    <form asp-action="Delete" asp-route-id="@t.Id" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" onclick="return confirm('Hard delete onaylaniyor — junction kayitlari da silinecek.');">Sil</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
