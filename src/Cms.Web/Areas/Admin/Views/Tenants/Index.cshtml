@model IReadOnlyList<Tenant>
@{
    ViewData["Title"] = "Tenant'lar";
    var includeInactive = (bool)(ViewData["IncludeInactive"] ?? false);
}

<h1>Tenant'lar</h1>

<p>
    <a asp-action="Create">+ Yeni Tenant</a>
    <span>|</span>
    @if (includeInactive)
    {
        <a asp-action="Index">Sadece Aktifler</a>
    }
    else
    {
        <a asp-action="Index" asp-route-includeInactive="true">Pasifler Dahil</a>
    }
</p>

@if (Model.Count == 0)
{
    <p><em>Hic tenant yok.</em></p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Slug</th>
                <th>Goruntu Adi</th>
                <th>Durum</th>
                <th>Olusturulma</th>
                <th>Islemler</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.Slug</td>
                <td>@t.DisplayName</td>
                <td>@(t.IsActive ? "Aktif" : "Pasif")</td>
                <td>@t.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    @if (t.IsActive)
                    {
                        <form asp-action="Deactivate" asp-route-id="@t.Id" method="post" style="display:inline;">
                            <button type="submit" onclick="return confirm('Tenant pasiflestirilsin mi?');">Pasiflestir</button>
                        </form>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}
