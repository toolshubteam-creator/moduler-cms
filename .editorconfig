root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.{json,yml,yaml,csproj,props,targets}]
indent_size = 2

[*.cs]
csharp_style_namespace_declarations = file_scoped:error
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:silent
csharp_prefer_braces = true:suggestion
dotnet_style_qualification_for_field = false:silent
dotnet_style_qualification_for_property = false:silent
dotnet_style_qualification_for_method = false:silent
dotnet_style_qualification_for_event = false:silent

# Sirali using (dis paketler once, sonra System.*)
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

[*.cs]
# CA1707 (underscore in member name): test isimleri icin gerekli
dotnet_diagnostic.CA1707.severity = none

# EF Core auto-generated migration dosyalari: block-style namespace ureyiyor, IDE0161 kapali
[**/Data/Migrations/*.cs]
dotnet_diagnostic.IDE0161.severity = none
csharp_style_namespace_declarations = block_scoped:silent
